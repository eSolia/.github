{
  "name": "Your Project Name",
  "sourcePaths": ["src/"],
  "apiPaths": ["src/routes/api/", "src/lib/server/"],
  "webPaths": ["src/routes/", "src/lib/components/"],
  "configPaths": ["."],
  "packageManager": "npm",
  "corsOrigins": ["esolia.co.jp", "yourapp.esolia.co.jp"],
  "extensions": [".ts", ".tsx", ".js", ".svelte"],
